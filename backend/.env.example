# Database Configuration
# Set these values to use PostgreSQL instead of SQLite

# PostgreSQL Host (default: localhost)
DB_HOST=localhost

# PostgreSQL Port (default: 5432)
DB_PORT=5432

# PostgreSQL Database Name
DB_NAME=godlywomen_db

# PostgreSQL User (default: postgres)
DB_USER=postgres

# PostgreSQL Password (REQUIRED for remote connections)
# For local development with peer authentication, this can be empty
DB_PASSWORD=

# Alternative: Use DATABASE_URL for cloud platforms
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Django Settings
DJANGO_SECRET_KEY=your-very-secret-key-here-change-in-production
DEBUG=True

# NextAuth Configuration
NEXTAUTH_SECRET=your-nextauth-secret-here-32-chars-minimum
NEXTAUTH_URL=http://localhost:3000

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Node Environment
NODE_ENV=development
